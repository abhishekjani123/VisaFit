OPENAI_API_KEY=your_key_here

# Optional: HTTP proxy for LinkedIn guest API (helps with rate limits)
# SCRAPER_PROXY_URL=http://user:pass@proxy.example.com:8080

# Optional: Turso cloud database (production)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token

# Local dev uses data/visafit.db automatically when Turso is not set
